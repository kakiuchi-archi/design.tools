  select:focus,input:focus{outline:none;border-color:var(--accent);}

  .spec-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;margin-top:6px;}
  .spec-card .sname{font-size:14px;font-weight:700;color:var(--text);font-family:'DM Mono',monospace;}
  .spec-card .sdims{font-size:11px;color:var(--text2);margin-top:3px;line-height:1.6;}
  .spec-card .suw{font-size:22px;font-weight:600;color:var(--accent);font-family:'DM Mono',monospace;margin-top:8px;}
  .spec-card .suw span{font-size:12px;color:var(--text2);font-weight:400;}

  .manual-uw{display:flex;align-items:center;gap:8px;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:6px 10px;margin-top:4px;}
  .manual-uw input{flex:1;background:transparent;border:none;color:var(--accent);font-family:'DM Mono',monospace;font-size:18px;font-weight:600;padding:0;}
  .manual-uw input:focus{outline:none;}
  .manual-uw span{font-size:12px;color:var(--text2);}

  .btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:7px;border:none;font-size:13px;font-weight:600;font-family:'Noto Sans JP',sans-serif;cursor:pointer;transition:all .15s;letter-spacing:.02em;}
  .btn-primary{background:var(--accent);color:#fff;width:100%;justify-content:center;}
  .btn-primary:hover{background:#6da0f9;transform:translateY(-1px);}
  .btn-secondary{background:var(--surface2);color:var(--text);border:1px solid var(--border);}
  .btn-secondary:hover{background:var(--border);}
  .btn-success{background:var(--success);color:#fff;}
  .btn-success:hover{background:#6adbb5;}

  .panel-right{padding:22px;display:flex;flex-direction:column;gap:18px;}
  .top-bar{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
  .proj-wrap{display:flex;align-items:center;gap:10px;flex:1;}
  .proj-wrap label{margin:0;white-space:nowrap;font-size:13px;}
  .proj-wrap input{max-width:300px;}

  .tbl-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:13px;background:var(--surface);border-radius:10px;overflow:hidden;border:1px solid var(--border);}
  th{background:var(--surface2);padding:9px 12px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.08em;color:var(--text2);white-space:nowrap;}
  td{padding:9px 12px;border-top:1px solid var(--border);font-size:13px;vertical-align:middle;}
  tr:hover td{background:rgba(26,111,212,.05);}
  td.num,th.num{text-align:right;font-family:'DM Mono',monospace;}

  .editable{cursor:text;border-radius:4px;padding:2px 5px;transition:background .15s;min-width:30px;display:inline-block;}
  .editable:hover{background:rgba(26,111,212,.10);}
  .editable:focus{outline:2px solid var(--accent);background:#e8f0fb;border-radius:4px;}

  .mtag{display:inline-block;background:rgba(79,142,247,.15);color:var(--accent);font-size:11px;padding:2px 8px;border-radius:4px;font-weight:500;white-space:nowrap;}
  .total-row td{background:var(--surface2);border-top:2px solid var(--accent);font-weight:700;}
  .wt-val{color:var(--accent2);font-family:'DM Mono',monospace;font-weight:600;}
  .total-weight{font-family:'DM Mono',monospace;font-size:18px;color:var(--accent2);}

  .row-actions{display:flex;gap:4px;align-items:center;opacity:1;}
  .bic{background:transparent;border:1px solid var(--border);color:var(--text2);cursor:pointer;border-radius:4px;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .12px;padding:0;}
  .bic:hover{background:var(--surface2);color:var(--text);}
  .bic.cp:hover{border-color:var(--success);color:var(--success);background:rgba(79,209,160,.1);}
  .bic.del:hover{border-color:var(--danger);color:var(--danger);background:rgba(247,108,108,.1);}

  .empty-state{text-align:center;padding:60px;color:var(--text2);}
  .empty-state .icon{font-size:44px;margin-bottom:12px;opacity:.4;}
  .empty-state p{font-size:13px;}

  .mode-tabs{display:flex;gap:0;margin-bottom:14px;border:1px solid var(--border);border-radius:7px;overflow:hidden;}
  .mode-tab{flex:1;padding:8px 4px;font-size:12px;font-weight:600;font-family:'Noto Sans JP',sans-serif;background:transparent;border:none;color:var(--text2);cursor:pointer;transition:all .15s;letter-spacing:.02em;}
  .mode-tab.active{background:var(--accent);color:#fff;}
  .mode-tab:not(.active):hover{background:var(--surface2);color:var(--text);}

  .other-card{background:var(--surface2);border:2px dashed var(--border);border-radius:8px;padding:14px;display:flex;flex-direction:column;gap:0;}
  .other-card label{margin-top:10px;}
  .other-card label:first-of-type{margin-top:0;}
  .uw-display{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 12px;margin-top:4px;display:flex;align-items:baseline;gap:6px;}
