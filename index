<header style="display:flex;align-items:center;gap:14px;">
  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" style="height:40px;width:auto;border-radius:6px;display:block;"><rect width="40" height="40" rx="6" fill="#1a6fd4"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="white" font-size="13" font-family="sans-serif" font-weight="bold">垣内</text></svg>
  <div style="display:flex;align-items:baseline;gap:14px;">
    <h1>鋼材重量計算ツール</h1>
    <span style="font-size:12px;color:var(--text2);letter-spacing:0.04em;">Produced by 垣内建築設計</span>
  </div>
</header>

<div class="main">
<div class="panel-left">

  <!-- ① 部位名称 -->
  <div>
    <div class="sec-title">入力</div>

    <label>部位名称 <span style="color:var(--text2);font-size:10px;font-weight:400;">（任意）</span></label>
    <input type="text" id="inPart" placeholder="" />
  </div>

  <!-- ② 素材・材種カテゴリ・規格サイズ（タブ切り替え） -->
  <div>
    <div class="mode-tabs">
      <button class="mode-tab active" id="tab-spec" onclick="switchMode('spec')">規格表から選択</button>
      <button class="mode-tab" id="tab-other" onclick="switchMode('other')">その他<br><span style="font-size:10px;font-weight:400;">（単位重量を手入力）</span></button>
    </div>

    <!-- 規格表モード -->
    <div id="mode-spec">
      <label>素材</label>
      <select id="selMaterial" onchange="onMaterialChange()">
        <option value="steel">スチール</option>
        <option value="stainless">ステンレス</option>
        <option value="aluminum">アルミ</option>
      </select>

      <label>材種カテゴリ</label>
      <select id="selCategory" onchange="onCategoryChange()"></select>

      <label>規格サイズ</label>
      <select id="selSpec" onchange="onSpecChange()"></select>
      <div id="specCard" class="spec-card" style="display:none;"></div>
    </div>

    <!-- その他モード -->
    <div id="mode-other" style="display:none;">
      <div class="other-card">
        <label>形状・規格名称 <span style="color:var(--text2);font-size:10px;font-weight:400;">（任意）</span></label>
        <input type="text" id="otherName" placeholder="" oninput="onOtherChange()" />

        <label>単位重量 (kg/m)</label>
        <input type="number" id="otherUW" placeholder="" step="0.001" min="0" oninput="onOtherChange()"
          style="font-family:'DM Mono',monospace;font-size:15px;color:var(--accent);" />
      </div>
    </div>
  </div>

  <!-- ③ 重量プレビュー（常時表示） -->
  <div>
    <label>重量プレビュー</label>
    <div class="uw-display" id="specPreview">
      <span class="uw-num" id="specPreviewVal">—</span>
      <span class="uw-unit" id="specPreviewUnit"> kg</span>
    </div>
  </div>

  <!-- ④ 長さ・⑤ 数量・⑥ 備考 -->
  <div>
    <label>長さ (mm)</label>
    <input type="number" id="inLength" placeholder="" step="1" min="0" oninput="updatePreview()" />

    <label>数量</label>
    <input type="number" id="inQty" placeholder="" step="1" min="1" value="1" oninput="updatePreview()" />

    <label>備考 <span style="color:var(--text2);font-size:10px;font-weight:400;">（任意）</span></label>
    <input type="text" id="inNote" placeholder="" />

    <button class="btn btn-primary" style="margin-top:14px;" onclick="addItem()">＋ リストに追加</button>
  </div>
</div>

<div class="panel-right">
  <div class="top-bar">
    <div class="proj-wrap">
      <label>工事名：</label>
      <input type="text" id="projectName" placeholder="" />
      <label style="margin-left:8px;">製品名：</label>
      <input type="text" id="productName" placeholder="" />
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button class="btn btn-secondary" onclick="clearAll()">全削除</button>
      <button class="btn btn-success" onclick="exportExcel()">EXCELに出力</button>
    </div>
  </div>
  <div id="tableWrap"></div>
</div>
</div>

