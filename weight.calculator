    {value:'BAR',  text:'丸棒'},
    {value:'STKMR_SQ',  text:'角鋼管 STKMR（小角径鋼管・正方形）'},
    {value:'STKMR_REC', text:'角鋼管 STKMR（小角径鋼管・長方形）'},
    {value:'STKR_SQ',   text:'角鋼管 STKR（角径鋼管・正方形）'},
    {value:'STKR_REC',  text:'角鋼管 STKR（角径鋼管・長方形）'},
    {value:'SQBAR', text:'角棒'},
    {value:'HW', text:'H形鋼（広幅）'},
    {value:'HM', text:'H形鋼（中幅）'},
    {value:'HN', text:'H形鋼（細幅）'},
  ],
  stainless: [
    {value:'__wip__', text:'━━ 工事中 ━━'},
  ],
  aluminum: [
    {value:'__wip__', text:'━━ 工事中 ━━'},
  ],
};

let items=[], counter=1, currentUW=0, currentSpec='', currentDims='';
let currentMode = 'spec';

function switchMode(mode){
  currentMode = mode;
  document.getElementById('mode-spec').style.display = mode==='spec' ? '' : 'none';
  document.getElementById('mode-other').style.display = mode==='other' ? '' : 'none';
  document.getElementById('tab-spec').classList.toggle('active', mode==='spec');
  document.getElementById('tab-other').classList.toggle('active', mode==='other');
  if(mode==='spec') onCategoryChange();
  else onOtherChange();
}

function onMaterialChange(){
  const mat = document.getElementById('selMaterial').value;
  const cats = MATERIAL_CATEGORIES[mat];
  const sel = document.getElementById('selCategory');
  sel.innerHTML = cats.map(c=>`<option value="${c.value}">${c.text}</option>`).join('');
  onCategoryChange();
}

function onCategoryChange(){
  const cat=document.getElementById('selCategory').value;
  const ss=document.getElementById('selSpec');
  const sc=document.getElementById('specCard');

  if(cat==='__wip__'){
    ss.style.display='none';
    sc.style.display='';
    sc.innerHTML=`<div style="color:var(--text2);font-size:13px;padding:4px 0;">このカテゴリは現在工事中です</div>`;
    currentUW=0; currentSpec=''; currentDims='';
    document.getElementById('uwEditVal').value='';
    return;
  }

  if(cat==='MANUAL'){
    ss.style.display='none';
    sc.style.display='none';
    currentUW=0; currentSpec='その他'; currentDims='';
    document.getElementById('uwEditVal').value='';
    return;
  }

  ss.style.display='';
  if(cat==='PL'){
    // 平鋼はtごとにoptgroupでグループ化
    const groups=[];
    const groupMap={};
    DB[cat].data.forEach((d,i)=>{
      const m=d.name.match(/FB-([\d.]+)[×x]/);
      const t=m?m[1]:'他';
      if(!groupMap[t]){groupMap[t]=[];groups.push(t);}
      groupMap[t].push({d,i});
    });
    ss.innerHTML=groups.map(t=>
      `<optgroup label="── 平鋼 ${t}mm ──">` +
      groupMap[t].map(({d,i})=>`<option value="${i}">${d.name}</option>`).join('') +
      `</optgroup>`
    ).join('');
  } else {
    ss.innerHTML=DB[cat].data.map((d,i)=>`<option value="${i}">${d.name}</option>`).join('');
  }
  onSpecChange();
}

function onSpecChange(){
  const cat=document.getElementById('selCategory').value;
  const idx=parseInt(document.getElementById('selSpec').value);
  const it=DB[cat].data[idx]; if(!it) return;
  currentUW=it.uw; currentSpec=it.name; currentDims=it.dims||'';
  const sc=document.getElementById('specCard');
  sc.style.display='';
  sc.innerHTML=`<div class="sname">${it.name}</div><div class="suw">${it.uw.toFixed(3)} <span>kg/m</span></div>`;
  updatePreview();
}

function onOtherChange(){
  currentUW=parseFloat(document.getElementById('otherUW').value)||0;
  currentSpec=document.getElementById('otherName').value.trim()||'その他';
  currentDims='';
  updatePreview();
}

function updatePreview(){
  const lenMm = parseFloat(document.getElementById('inLength').value)||0;
  const qty = parseInt(document.getElementById('inQty').value)||1;
  const el = document.getElementById('specPreviewVal');
  const unit = document.getElementById('specPreviewUnit');
  if(currentUW>0 && lenMm>0){
    el.textContent = (currentUW*(lenMm/1000)*qty).toFixed(2);
    unit.textContent = ' kg';
  } else {
    el.textContent = '—';
    unit.textContent = ' kg';
  }
}

function addItem(){
  if(currentUW<=0){alert('鋼材を選択するか単位重量を入力してください。');return;}
  const part=document.getElementById('inPart').value.trim();
  const lengthMm=parseFloat(document.getElementById('inLength').value);
  const qty=parseInt(document.getElementById('inQty').value)||1;
  const note=document.getElementById('inNote').value.trim();
  if(isNaN(lengthMm)||lengthMm<=0){alert('長さを入力してください。');return;}
  const lengthM=lengthMm/1000;
  const isManual=(currentMode==='other');
  items.push({no:counter++,spec:currentSpec,dims:currentDims,unitWeight:currentUW,part,lengthMm,lengthM,qty,weight:currentUW*lengthM*qty,note,isManual});
  renderTable();
  document.getElementById('inLength').value='';
  document.getElementById('inQty').value='1';
  document.getElementById('inNote').value='';
}

function deleteItem(no){items=items.filter(i=>i.no!==no);renderTable();}
function copyItem(no){
  const src=items.find(i=>i.no===no); if(!src) return;
  const idx=items.findIndex(i=>i.no===no);
  items.splice(idx+1,0,{...src,no:counter++});
  renderTable();
}
function moveItem(no,dir){
  const idx=items.findIndex(i=>i.no===no),si=idx+dir;
  if(si<0||si>=items.length) return;
  [items[idx],items[si]]=[items[si],items[idx]];
  renderTable();
}
function updateField(no,field,value){
  const it=items.find(i=>i.no===no); if(!it) return;
  if(field==='lengthMm'){
    const v=parseFloat(value); if(!isNaN(v)&&v>0){it.lengthMm=v;it.lengthM=v/1000;}
  } else if(field==='qty'||field==='unitWeight'){
    const v=parseFloat(value); if(!isNaN(v)&&v>0)it[field]=v;
  } else {
    it[field]=value;
  }
  it.weight=it.unitWeight*it.lengthM*it.qty;
  const wc=document.getElementById('wt_'+no); if(wc) wc.textContent=it.weight.toFixed(2);
  updateTotal();
}
function updateTotal(){const el=document.getElementById('totalWeight');if(el)el.textContent=items.reduce((s,i)=>s+i.weight,0).toFixed(2);}
function clearAll(){if(!items.length)return;if(!confirm('リストを全削除しますか？'))return;items=[];counter=1;renderTable();}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function renderTable(){
  const wrap=document.getElementById('tableWrap');
  if(!items.length){
    wrap.innerHTML=`<div class="empty-state"><div class="icon">📋</div><p>左パネルで鋼材を選択し「リストに追加」してください。</p></div>`;
    return;
  }
  const total=items.reduce((s,i)=>s+i.weight,0);
  wrap.innerHTML=`<div class="tbl-wrap"><table>
  <thead><tr>
    <th style="width:38px;">NO.</th>
    <th>部位名称</th>
    <th>規格・寸法</th>
    <th class="num" style="width:90px;">長さ(mm)</th>
    <th class="num" style="width:50px;">数量</th>
    <th class="num" style="width:100px;">単重(kg/m)</th>
    <th class="num" style="width:90px;">重量(kg)</th>
    <th>備考</th>
    <th style="width:116px;text-align:center;font-size:9px;">操作</th>
  </tr></thead>
  <tbody>
  ${items.map((it,idx)=>`
  <tr id="row_${it.no}">
    <td style="color:var(--text2);font-size:12px;text-align:center;">${idx+1}</td>
    <td><span class="editable" contenteditable="true"
      onblur="updateField(${it.no},'part',this.textContent.trim())"
      onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
    >${escHtml(it.part)}</span></td>
    <td style="font-size:11px;">
      ${it.isManual
        ? `<span class="editable" contenteditable="true"
            onblur="updateField(${it.no},'spec',this.textContent.trim())"
            onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
            style="font-weight:500;">${escHtml(it.spec)}</span>`
        : `<span style="font-weight:500;">${escHtml(it.spec)}</span>`
      }
    </td>
    <td class="num"><span class="editable" contenteditable="true"
      onblur="updateField(${it.no},'lengthMm',this.textContent.trim())"
      onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
    >${it.lengthMm}</span></td>
    <td class="num"><span class="editable" contenteditable="true"
      onblur="updateField(${it.no},'qty',this.textContent.trim())"
      onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
    >${it.qty}</span></td>
    <td class="num">
      ${it.isManual
        ? `<span class="editable" contenteditable="true"
            onblur="updateField(${it.no},'unitWeight',this.textContent.trim())"
            onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
          >${it.unitWeight.toFixed(3)}</span>`
        : `<span style="font-family:'DM Mono',monospace;">${it.unitWeight.toFixed(3)}</span>`
      }
    </td>
    <td class="num"><span id="wt_${it.no}" class="wt-val">${it.weight.toFixed(2)}</span></td>
    <td><span class="editable" contenteditable="true"
      onblur="updateField(${it.no},'note',this.textContent.trim())"
      onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur();}"
      style="font-size:12px;color:var(--text2);"
    >${escHtml(it.note)}</span></td>
    <td><div class="row-actions" style="opacity:1;justify-content:center;">
      <button class="bic" title="上へ" onclick="moveItem(${it.no},-1)">↑</button>
      <button class="bic" title="下へ" onclick="moveItem(${it.no},1)">↓</button>
      <button class="bic cp" title="コピー追加" onclick="copyItem(${it.no})">⧉</button>
      <button class="bic del" title="削除" onclick="deleteItem(${it.no})">✕</button>
    </div></td>
  </tr>`).join('')}
  <tr class="total-row">
    <td colspan="6" style="text-align:right;font-size:13px;color:var(--text2);letter-spacing:.08em;">総　重　量</td>
    <td class="num"><span id="totalWeight" class="total-weight">${total.toFixed(2)}</span> <span style="font-size:11px;color:var(--text2);">kg</span></td>
    <td colspan="2"></td>
  </tr>
  </tbody></table></div>`;
}

async function exportExcel(){
  if(!items.length){alert('リストが空です。');return;}
  const proj = document.getElementById('projectName').value || '工事名';
  const prod = document.getElementById('productName').value || '';
  const today = new Date();
  const ds = `${today.getFullYear()}年${today.getMonth()+1}月${today.getDate()}日`;
  const total = items.reduce((s,i)=>s+i.weight, 0);

  const wb = new ExcelJS.Workbook();

  // ===== シート1: 重量一覧表 =====
  const ws = wb.addWorksheet('重量一覧表');

  // 列幅
  ws.getColumn('A').width = 5.625;
  ws.getColumn('B').width = 24.875;
  ws.getColumn('C').width = 25.625;
  ws.getColumn('D').width = 9.625;
  ws.getColumn('E').width = 6.625;
  ws.getColumn('F').width = 11.625;
  ws.getColumn('G').width = 11.625;
  ws.getColumn('H').width = 30.625;

  // 全行の行高
  const totalRows = 4 + items.length + 1;
  for(let r = 1; r <= totalRows; r++){
    ws.getRow(r).height = 20.1;
  }

  const font = { name:'ＭＳ Ｐゴシック', size:12 };

  // 行1: タイトル（A1:C1結合）
  ws.mergeCells('A1:C1');
  const r1a = ws.getCell('A1');
  r1a.value = `「${proj}」 重量一覧表`;
  r1a.font = font;
  r1a.alignment = { vertical:'center', horizontal:'left' };

  // 行2: 製品名（A2:C2結合）・作成日（H2）
  ws.mergeCells('A2:C2');
  const r2a = ws.getCell('A2');
  r2a.value = prod ? `製品名：${prod}` : '';
  r2a.font = font;
  r2a.alignment = { vertical:'center', horizontal:'left' };
  const r2h = ws.getCell('H2');
  r2h.value = `作成日：${ds}`;
  r2h.font = font;
  r2h.alignment = { vertical:'center', horizontal:'right' };

  // 行3: 空白

  // 行4: ヘッダー
  const headers = ['NO.','部　位','規格・寸法','長さ(mm)','数量','単重(kg/m)','重量(kg)','備　考'];
  const hRow = ws.getRow(4);
  headers.forEach((h, i) => {
    const cell = hRow.getCell(i+1);
    cell.value = h;
    cell.font = font;
    cell.alignment = { vertical:'center', horizontal:'center' };
    cell.border = {
      top:    { style:'double' },
      bottom: { style:'double' },
      left:   { style: i===0 ? 'double' : 'thin' },
      right:  { style: i===7 ? 'double' : 'thin' },
    };
  });

  // データ行（最終行のbottomはdouble）
  const lastDataRow = 4 + items.length;
  items.forEach((it, idx) => {
    const rn = 5 + idx;
    const isLast = idx === items.length - 1;
    const row = ws.getRow(rn);
    row.height = 20.1;
    const vals = [idx+1, it.part, it.spec, it.lengthMm, it.qty, it.unitWeight, null, it.note];
    vals.forEach((v, i) => {
      const cell = row.getCell(i+1);
      cell.font = font;
      if(i === 6){
        // 重量 = 長さ(mm)/1000 * 数量 * 単重
        cell.value = { formula: `D${rn}/1000*E${rn}*F${rn}` };
        cell.numFmt = '0.00';
      } else {
        cell.value = v;
      }
      cell.alignment = { vertical:'center', horizontal: i===0||i===3||i===4||i===5||i===6 ? 'center' : 'left' };
      cell.border = {
        top:    idx > 0 ? { style:'thin' } : undefined,
        bottom: { style: isLast ? 'double' : 'thin' },
        left:   { style: i===0 ? 'double' : 'thin' },
        right:  { style: i===7 ? 'double' : 'thin' },
      };
    });
  });

  // 総重量行（A〜E・Hはtop:doubleのみ、F・Gは四方に罫線）
  const totalRowN = 5 + items.length;
  const tRow = ws.getRow(totalRowN);
  tRow.height = 20.1;
  for(let i = 0; i < 8; i++){
    const cell = tRow.getCell(i+1);
    cell.font = font;
    if(i === 5){
      // F列：総重量ラベル
      cell.value = '総重量';
      cell.alignment = { vertical:'center', horizontal:'center' };
      cell.border = { top:{style:'double'}, bottom:{style:'double'}, left:{style:'double'}, right:{style:'thin'} };
    } else if(i === 6){
      // G列：総重量値
      cell.value = { formula: `SUM(G5:G${totalRowN-1})` };
      cell.numFmt = '0.00';
      cell.alignment = { vertical:'center', horizontal:'center' };
      cell.border = { top:{style:'double'}, bottom:{style:'double'}, left:{style:'thin'}, right:{style:'double'} };
    } else {
      // A〜E・H列：上罫線のみ
      cell.border = { top:{style:'double'} };
      cell.alignment = { vertical:'center' };
    }
  }

  // ===== シート2: 単位重量一覧 =====
  const ws2 = wb.addWorksheet('単位重量一覧');
  ws2.getColumn('A').width = 36;
  ws2.getColumn('B').width = 16;
  ws2.getColumn('C').width = 24;
  ['規格名','単位重量(kg/m)','部位'].forEach((h,i) => {
    const cell = ws2.getRow(1).getCell(i+1);
    cell.value = h;
    cell.font = font;
  });
  items.forEach((it, idx) => {
    const row = ws2.getRow(idx+2);
    row.getCell(1).value = it.spec;
    row.getCell(2).value = it.unitWeight;
    row.getCell(3).value = it.part;
    [1,2,3].forEach(i => { row.getCell(i).font = font; });
  });

  // ダウンロード
  const buf = await wb.xlsx.writeBuffer();
  const blob = new Blob([buf], {type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${proj}${prod?'_'+prod:''}_重量計算.xlsx`;
  a.click();
  URL.revokeObjectURL(url);
}

// 初期化
onMaterialChange();
</script>
</body>
</html>
